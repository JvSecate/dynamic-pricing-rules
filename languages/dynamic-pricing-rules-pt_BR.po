msgid "Specific categories"
msgstr "Categorias específicas"

#: dynamic-pricing-rules.php:195 dynamic-pricing-rules.php:255
msgid "Count quantity by"
msgstr "Contar quantidade por"

#: dynamic-pricing-rules.php:199
msgid "Discount tiers"
msgstr "Faixas de desconto"

#: dynamic-pricing-rules.php:202
msgid "Leave Max empty for open-ended tiers like 6+ items."
msgstr "Deixe Máx. vazio para faixas sem limite, como 6+ itens."

#: dynamic-pricing-rules.php:209
msgid "Buy X, Get Y Free"
msgstr "Compre X, leve Y grátis"

#: dynamic-pricing-rules.php:214
msgid "Enable buy X, get Y free"
msgstr "Ativar Compre X, leve Y grátis"

#: dynamic-pricing-rules.php:222
msgid "Offer label"
msgstr "Rótulo da oferta"

#: dynamic-pricing-rules.php:229
msgid "Reserved for cart item display if this offer is shown beside products."
