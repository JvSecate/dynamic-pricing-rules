#: dynamic-pricing-rules.php:233
msgid "Offer"
msgstr "Oferta"

#: dynamic-pricing-rules.php:235
msgid "Buy"
msgstr "Compre"

#: dynamic-pricing-rules.php:237
msgid "get"
msgstr "leve"

#: dynamic-pricing-rules.php:239
msgid "free"
msgstr "grátis"

#: dynamic-pricing-rules.php:262
msgid "Save pricing rules"
msgstr "Salvar regras de preço"

#: dynamic-pricing-rules.php:280
msgid "All products"
