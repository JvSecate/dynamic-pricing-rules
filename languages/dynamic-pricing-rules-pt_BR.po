msgid "Discount type"
msgstr "Tipo de desconto"

#: dynamic-pricing-rules.php:396
msgid "Amount"
msgstr "Valor"

#: dynamic-pricing-rules.php:4
msgid "Adds WooCommerce quantity tiers, product/category bulk discounts, and buy X get Y offers."
msgstr "Adiciona faixas de quantidade no WooCommerce, descontos em massa por produto/categoria e ofertas Compre X, leve Y."

